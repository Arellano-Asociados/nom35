# Variables de entorno de Constata (apps/web). Copia a .env.local para desarrollo.
# Los valores locales los imprime `pnpm exec supabase start` (llaves estándar de
# desarrollo, no son secretos). En producción, TODOS los valores vienen del entorno
# del despliegue; jamás se commitean (regla inviolable 9).

# ── Supabase ─────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor. En producción, el service_role es el secreto más sensible del sistema.
SUPABASE_SERVICE_ROLE_KEY=
# Conexión directa a Postgres (E2E y scripts locales).
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# ── Aplicación ───────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ── Correo ───────────────────────────────────────────────────────────────────
# Producción: RESEND_API_KEY + MAIL_FROM (OBLIGATORIO con Resend; formato
# "Constata <avisos@dominio.mx>"). Desarrollo: MAILPIT_URL (bandeja local del
# Supabase local; nada se envía de verdad).
# RESEND_API_KEY=
# MAIL_FROM=
MAILPIT_URL=http://127.0.0.1:54324

# ── Anti-bot (Cloudflare Turnstile) ──────────────────────────────────────────
# Sin estas llaves el reto NO se exige (desarrollo/E2E). Producción: llaves reales
# + activar [auth.captcha] (provider turnstile) en el dashboard de Supabase Auth.
# Llaves de prueba oficiales (siempre pasan):
#   site key  1x00000000000000000000AA · secret 1x0000000000000000000000000000000AA
# NEXT_PUBLIC_TURNSTILE_SITE_KEY=
# TURNSTILE_SECRET_KEY=

# ── Cron de recordatorios automáticos (Fase 3) ───────────────────────────────
# Vercel manda "Authorization: Bearer CRON_SECRET" al invocar /api/cron/recordatorios
# (vercel.json). Sin la variable, el endpoint responde 401 y el cron queda inerte.
# CRON_SECRET=
