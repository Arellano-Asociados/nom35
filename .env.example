# Copia este archivo a .env.local (apps/web) o .env y llena los valores.
# NUNCA commitear archivos .env con valores reales (regla 9 de CLAUDE.md).

# Supabase (valores locales: los imprime `pnpm exec supabase start`)
NEXT_PUBLIC_SUPABASE_URL=http://127.0.0.1:54321
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Solo servidor — jamás exponer al cliente
SUPABASE_SERVICE_ROLE_KEY=
# Conexión directa a Postgres (suites de aislamiento y E2E)
SUPABASE_DB_URL=postgresql://postgres:postgres@127.0.0.1:54322/postgres

# Correo transaccional (interfaz MailProvider; Resend por defecto)
RESEND_API_KEY=
MAIL_FROM=notificaciones@example.com

# URL pública de la app (enlaces tokenizados en correos)
NEXT_PUBLIC_APP_URL=http://localhost:3000
